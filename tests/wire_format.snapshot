          "gateways": [
            {
              "name": "Gateway-1",
              "address": "vpn.example.com",
              "priority": 5,
              "priorityRules": [
                {
                  "name": "rule",
                  "priority": 1
                }
              ]
            }
          ]
        },
        "sessionInfo": {
          "lifetimeSecs": 43200,
          "userExpires": 1900000000,
          "expiresInHuman": "12h",
          "lifetimeWarning": {
            "prior_secs": 1800,
            "message": "Session expires soon"
          },
          "inactivityWarning": {
            "prior_secs": 600,
            "message": "Idle"
          },
          "adminLogoutMessage": "Logged out by admin",
          "allowExtendSession": true
        },
        "tunIface": "tun0",
        "ipv4": "10.0.0.2",
        "ipv6": "fd00::2"
      }
    },
    "vpnc_script": "/etc/vpnc-script",
    "csd_wrapper": "/usr/bin/hipreport.sh",
    "auth_executable": "/usr/bin/gpauth"
  }
}

