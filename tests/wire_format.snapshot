## WsRequest::Connect
{
  "Connect": {
    "info": {
      "portal": "portal.example.com",
      "gateway": {
        "name": "Gateway-1",
        "address": "vpn.example.com",
        "priority": 5,
        "priorityRules": [
          {
            "name": "rule",
            "priority": 1
          }
        ]
      },
      "gateways": [
        {
          "name": "Gateway-1",
          "address": "vpn.example.com",
          "priority": 5,
          "priorityRules": [
            {
              "name": "rule",
              "priority": 1
            }
          ]
        }
      ]
    },
    "args": {
      "cookie": "authcookie=AUTH",
      "vpnc_script": "/etc/vpnc-script",
      "user_agent": "PAN GlobalProtect",
      "os": "Linux",
      "os_version": "Linux 6.0",
      "client_version": "6.0.0",
      "certificate": "/path/cert.pem",
      "sslkey": "/path/key.pem",
      "key_password": "secret",
      "hip": true,
      "csd_uid": 1000,
      "csd_wrapper": "/usr/bin/hipreport.sh",
      "reconnect_timeout": 300,
      "mtu": 1400,
      "disable_ipv6": true,
      "no_dtls": true,
      "local_hostname": "host",
      "force_dpd": 30,
      "no_xmlpost": true,
      "allowExtendSession": true,
      "dns_domains": [
        "corp.acme.example",
        "acme.example"
      ]
    }
  }
}

